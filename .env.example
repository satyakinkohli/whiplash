# LLM extractor (required)
ANTHROPIC_API_KEY=

# Storage (required for production; pipeline can run dry-run without these)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Daily digest email (required for digest)
RESEND_API_KEY=
DIGEST_FROM_EMAIL=digest@whiplash.local
DIGEST_TO_EMAIL=

# API sources (required when api/* sources are enabled)
SONGKICK_API_KEY=
BANDSINTOWN_APP_ID=

# Runtime
WHIPLASH_USER_AGENT=whiplash-pipeline (+https://github.com/<owner>/whiplash)
WHIPLASH_LOG_LEVEL=info
WHIPLASH_DRY_RUN=false
